generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model SchoolClass {
  id              String         @id @default(cuid())
  group           ClassGroup
  name            String
  slug            String         @unique
  homeroomTeacher String?
  totalStudents   Int            @default(0)
  maleStudents    Int            @default(0)
  femaleStudents  Int            @default(0)
  introduction    String?
  mainImageUrl    String?
  active          Boolean        @default(true)
  displayOrder    Int            @default(0)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  sections        ClassSection[]
  markers         MapMarker[]
  scheduleItems   ScheduleItem[]
}

model ClassSection {
  id           String      @id @default(cuid())
  classId      String
  title        String
  body         String?
  imageUrl     String?
  videoUrl     String?
  active       Boolean     @default(true)
  displayOrder Int         @default(0)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  buttonLabel  String?
  buttonUrl    String?
  eyebrow      String?
  layout       String      @default("TEXT")
  schoolClass  SchoolClass @relation(fields: [classId], references: [id], onDelete: Cascade)
}

model TeacherDepartment {
  id           String                     @id @default(cuid())
  fullName     String
  shortName    String
  slug         String                     @unique
  introduction String?
  mainImageUrl String?
  active       Boolean                    @default(true)
  displayOrder Int                        @default(0)
  createdAt    DateTime                   @default(now())
  updatedAt    DateTime                   @updatedAt
  markers      MapMarker[]
  sections     TeacherDepartmentSection[]
}

model TeacherDepartmentSection {
  id           String            @id @default(cuid())
  departmentId String
  title        String
  body         String?
  imageUrl     String?
  videoUrl     String?
  active       Boolean           @default(true)
  displayOrder Int               @default(0)
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  department   TeacherDepartment @relation(fields: [departmentId], references: [id], onDelete: Cascade)
}

model EventMap {
  id            String      @id @default(cuid())
  title         String      @default("Тайлант өдөрлөгийн мап")
  backgroundUrl String?
  googleMapsUrl String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  markers       MapMarker[]
}

model MapMarker {
  id           String             @id @default(cuid())
  eventMapId   String
  name         String
  type         MapMarkerType
  xPercent     Float
  yPercent     Float
  classId      String?
  departmentId String?
  description  String?
  status       String?
  active       Boolean            @default(true)
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  schoolClass  SchoolClass?       @relation(fields: [classId], references: [id])
  department   TeacherDepartment? @relation(fields: [departmentId], references: [id])
  eventMap     EventMap           @relation(fields: [eventMapId], references: [id], onDelete: Cascade)
}

model LiveStatus {
  id             String   @id @default(cuid())
  currentStage   String?
  currentClassId String?
  updatedAt      DateTime @updatedAt
  createdAt      DateTime @default(now())
}

model Announcement {
  id        String   @id @default(cuid())
  title     String?
  body      String
  enabled   Boolean  @default(false)
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())
}

model ScheduleItem {
  id           String       @id @default(cuid())
  title        String
  description  String?
  startTime    String
  endTime      String?
  location     String?
  classId      String?
  active       Boolean      @default(true)
  displayOrder Int          @default(0)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  schoolClass  SchoolClass? @relation(fields: [classId], references: [id])
}

model UploadedFile {
  id        String   @id @default(cuid())
  fileName  String
  url       String
  mimeType  String
  size      Int
  createdAt DateTime @default(now())
}

enum ClassGroup {
  HIGH
  MIDDLE
  PRIMARY
}

enum MapMarkerType {
  STAGE
  BOOTH
  CLASS_LOCATION
  INFO
  ENTRANCE
  CUSTOM
}
